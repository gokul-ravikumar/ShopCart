<% layout("./boilerplate/boilerplate.ejs") -%>

<div
  class="flex flex-col items-center gap-4 p-5 max-w-7xl mx-auto w-full overflow-x-hidden"
>
  <!-- 🛒 Product Grid -->
  <div
    class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 justify-items-center w-full"
  >
   <% for (let product of products) { %>

<a href="/product/<%= product._id %>" 
   class="block max-w-sm bg-white shadow-xl rounded-2xl transition-transform transform hover:scale-105 hover:shadow-2xl">

  <img
    src="<%= product.image[0].url %>"
    alt="<%= product.image[0].filename %>"
    class="rounded-t-2xl object-cover w-full h-56"
  />

  <div class="p-5 bg-white rounded-b-2xl text-center">

    <h5 class="mb-2 text-xl font-bold tracking-tight text-gray-900">
      <%= product.title %>
    </h5>

    <p class="mb-3 font-normal text-gray-700">
      <%= product.description %>
    </p>

    <div class="flex justify-center items-center gap-1 mb-3">
      <span class="text-yellow-400 text-lg">★</span>
      <span class="text-gray-700 font-medium">
        <%= product.rating ? product.rating.toFixed(1) : (Math.random()*2+3).toFixed(1) %>
      </span>
    </div>

    <p class="mb-3 font-semibold text-orange-600">
      $<%= product.price %>
    </p>

  </div>

</a>

<% } %>
  </div>
</div>
