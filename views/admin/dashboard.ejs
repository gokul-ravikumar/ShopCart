<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100 text-gray-900 w-full">
    <!-- Sidebar + Header Layout -->
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <%- include("partials/sidebar") %>
      <!-- Main Content -->
      <div class="flex-1 flex flex-col">
        <!-- Header -->
        <%- include("partials/header", { pageTitle: " Dashboard" }) %>

        <!-- Body Content -->
        <main class="p-6 space-y-6">
          <!-- KPI Cards -->
          <section class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-white p-4 shadow rounded-lg">
              <p class="text-sm text-gray-500">Total Users</p>
              <h2 class="text-2xl font-bold">1,230</h2>
            </div>
            <div class="bg-white p-4 shadow rounded-lg">
              <p class="text-sm text-gray-500">Total Sales</p>
              <h2 class="text-2xl font-bold">&#8377;45,800</h2>
            </div>
            <div class="bg-white p-4 shadow rounded-lg">
              <p class="text-sm text-gray-500">Total Orders</p>
              <h2 class="text-2xl font-bold">389</h2>
            </div>
            <div class="bg-white p-4 shadow rounded-lg">
              <p class="text-sm text-gray-500">Products in Stock</p>
              <h2 class="text-2xl font-bold">100</h2>
            </div>
          </section>

          <!-- Charts Placeholder -->
          <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div
              class="bg-white shadow rounded-lg h-64 flex items-center justify-center w-full"
            >
              <canvas id="myChart" class="w-full"></canvas>
            </div>
            <div
              class="bg-white shadow rounded-lg h-64 flex items-center justify-center w-full"
            >
              <canvas id="myChart2" class="w-full"></canvas>
            </div>
          </section>

          <!-- Recent Orders -->
          <section class="bg-white p-4 shadow rounded-lg">
            <h3 class="text-lg font-semibold mb-4">Recent Orders</h3>
            <div class="overflow-x-auto">
              <table class="min-w-full table-auto">
                <thead>
                  <tr class="bg-gray-100 text-left text-sm">
                    <th class="p-2">Customer</th>
                    <th class="p-2">Amount</th>
                    <th class="p-2">Status</th>
                  </tr>
                </thead>
                  <tbody>
                    <% orders.forEach((order, index) => { %>
                      <tr>
                        <td class="p-2"><%= order.userId.name %></td>
                        <td class="p-2">₹<%= order.totalAmount.toFixed(2) %></td>
                        <td class="p-2"><%= order.orderStatus %></td>
                      </tr>
                    <% }) %>
                  </tbody>
              </table>
            </div>
          </section>
        </main>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </body>
</html>//

<script>
      console.log("hii");
      const growthData = <%- JSON.stringify(userGrowth) %>;
      console.log("growth data:", growthData);

      const ctx = document.getElementById("myChart");
      const ctx2 = document.getElementById("myChart2");

      if (ctx) {
      new Chart(ctx, {
          type: "line",
          data: {
            labels: growthData.map(item => item._id), 
            datasets: [
              {
                label: "Votes",
                data: growthData.map(item => item.count), 
                borderWidth: 1,
              },
            ],
          },
          options: {
            scales: {
              y: {
                beginAtZero: true,
              },
            },
          },
        });
      }

      if (ctx2) {
        let activeUser = <%= active %>;
        let blockedUser = <%= blocked %>;

        new Chart(ctx2, {
          type: "pie",
          data: {
            labels: ["Active", "Blocked"],
            datasets: [
              {
                label: "User Distribution",
                data: [activeUser,blockedUser],
                backgroundColor: ["rgb(54, 162, 235)", "rgb(255, 99, 132)"],
              },
            ],
          },
        });
      }
    </script>
