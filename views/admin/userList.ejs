<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100 text-gray-900 w-full">
    <!-- Sidebar + Header Layout -->
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <%- include("partials/sidebar") %>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col">
        <%- include("partials/header", { pageTitle: "User Dashboard" }) %>

        <!-- Main Body -->
        <main class="p-6 space-y-6">
          <!-- Add User Button -->
          <div class="flex justify-end">
            <a
              href="/admin/user/add"
              class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl shadow-md font-medium text-sm transition transform hover:-translate-y-0.5"
            >
              + Add User
            </a>
          </div>

          <!-- Users Table -->
          <section class="bg-white p-6 shadow rounded-lg">
            <h2 class="text-lg font-semibold mb-4">All Users</h2>

            <div
              class="relative overflow-x-auto rounded-xl border border-gray-200"
            >
              <table class="w-full text-sm text-left text-gray-700">
                <thead class="bg-gray-100 text-left">
                  <tr>
                    <th class="p-3">#</th>
                    <th class="p-3">Name</th>
                    <th class="p-3">Email</th>
                    <th class="p-3">Phone</th>
                    <th class="p-3">Status</th>
                    <th class="p-3">Joined</th>
                    <th class="p-3 text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (users && users.length> 0) { %> <% users.forEach((user,
                  i)=> { %>
                  <tr class="border-b hover:bg-gray-50">
                    <td class="p-3">
                      <%= (currentPage - 1) * 10 + i + 1 %>
                    </td>
                    <td class="p-3"><%= user.name %></td>
                    <td class="p-3"><%= user.email %></td>
                    <td class="p-3"><%= user.phone %></td>
                    <td class="p-3">
                      <span
                        class="<%= user.isBlocked ? 'text-red-600 font-semibold' : 'text-green-600 font-semibold' %>"
                      >
                        <%= user.isBlocked ? 'Blocked' : 'Active' %>
                      </span>
                    </td>
                    <td class="p-3">
                      <%= user.createdAt ? user.createdAt.toDateString() : '—'
                      %>
                    </td>
                    <td class="p-3 text-center space-x-2">
                      <% if (user.isBlocked) { %>
                      <!-- Unblock button -->
                      <form
                        action="/admin/user/unblock/<%= user._id %>"
                        method="POST"
                        class="inline"
                      >
                        <button
                          type="submit"
                          class="bg-green-500 text-white px-3 py-1 rounded-lg hover:bg-green-600 transition"
                        >
                          Unblock
                        </button>
                      </form>
                      <% } else { %>
                      <!-- Block button -->
                      <form
                        action="/admin/user/block/<%= user._id %>"
                        method="POST"
                        class="inline"
                      >
                        <button
                          type="submit"
                          class="bg-red-500 text-white px-3 py-1 rounded-lg hover:bg-red-600 transition"
                        >
                          Block
                        </button>
                      </form>
                      <% } %>

                      <!-- Delete button -->
                      <a
                        href="/admin/user/delete/<%= user._id %>"
                        onclick="return confirm('Are you sure you want to delete this user?')"
                        class="bg-gray-300 text-gray-700 px-3 py-1 rounded-lg hover:bg-gray-400 transition"
                      >
                        Delete
                      </a>
                    </td>
                  </tr>
                  <% }) %> <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center text-gray-500 p-4">
                      No users found
                    </td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </section>

          <!-- Pagination -->
              <div class="flex flex-col md:flex-row items-center justify-between mt-6">
                
                <p class="text-sm text-gray-600 mb-3 md:mb-0">
                  Page
                  <span class="font-semibold text-gray-900">
                    <%= currentPage %>
                  </span>
                  of
                  <span class="font-semibold text-gray-900">
                    <%= totalPages %>
                  </span>
                </p>

                <div class="flex items-center gap-2">

                  <% if (currentPage > 1) { %>
                    <a
                      href="?page=<%= currentPage - 1 %>"
                      class="px-3 py-1.5 text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition text-sm shadow-sm"
                    >
                      ← Prev
                    </a>
                  <% } %>

                  <% for (let i = 1; i <= totalPages; i++) { %>
                    <a
                      href="?page=<%= i %>"
                      class="px-3 py-1.5 border text-sm rounded-lg transition shadow-sm
                      <%= i === currentPage
                        ? 'bg-blue-600 text-white border-blue-600'
                        : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-100' %>"
                    >
                      <%= i %>
                    </a>
                  <% } %>

                  <% if (currentPage < totalPages) { %>
                    <a
                      href="?page=<%= currentPage + 1 %>"
                      class="px-3 py-1.5 text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition text-sm shadow-sm"
                    >
                      Next →
                    </a>
                  <% } %>

                </div>
              </div>

          <!-- Charts Section -->
          <section class="grid md:grid-cols-2 gap-6">
            <div class="bg-white p-6 shadow rounded-lg">
              <h3 class="text-lg font-semibold mb-4">User Growth</h3>
              <canvas id="myChart"></canvas>
            </div>

            <div
              class="bg-white p-6 shadow rounded-lg flex flex-col items-center justify-center"
            >
              <h3 class="text-lg font-semibold mb-4">User Distribution</h3>
              <div class="w-48 h-48">
                <!-- 🔹 Makes the chart smaller -->
                <canvas id="myChart2"></canvas>
              </div>
            </div>
          </section>
        </main>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
    <script>
      const ctx = document.getElementById("myChart");
      const ctx2 = document.getElementById("myChart2");

      if (ctx) {
          fetch("/admin/user")
          .then(res => res.json())
          .then(usersData => {

            const counts = {};
            usersData.forEach(user => {
              if (!user.createdAt) return;

              const date = new Date(user.createdAt)
                .toISOString()
                .split("T")[0];

              if (!counts[date]) counts[date] = 0;
              counts[date]++;
            });

            const chartData = Object.keys(counts)
              .sort()
              .map(date => ({
                x: date,
                y: counts[date]
              }));

            new Chart(ctx, {
              type: "line",
              data: {
                datasets: [{
                  label: "Users per Day",
                  data: chartData
                }]
              },
              options: {
                scales: {
                  x: {
                    type: "time",
                    time: { unit: "day" }
                  },
                  y: {
                    beginAtZero: true
                  }
                }
              }
            });
          });
        }

      if (ctx2) {
        new Chart(ctx2, {
          type: "pie",
          data: {
            labels: ["Active", "Blocked"],
            datasets: [
              {
                label: "User Distribution",
                data: [80, 20],
                backgroundColor: ["rgb(54, 162, 235)", "rgb(255, 99, 132)"],
              },
            ],
          },
        });
      }
    </script>
  </body>
</html>
