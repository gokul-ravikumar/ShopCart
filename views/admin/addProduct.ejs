<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Product</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"
    />

    <style>
      #previewContainer img {
        display: block;
        max-width: 100%;
      }
    </style>
  </head>

  <body class="bg-gray-50 text-gray-900 font-inter min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-white border-r hidden md:block shadow-sm">
        <div class="p-6 text-2xl font-bold border-b text-blue-600">
          Admin Panel
        </div>
        <nav class="p-4 space-y-4">
          <a
            href="/admin/dashboard"
            class="block text-gray-700 hover:text-blue-500 transition"
            >Dashboard</a
          >
          <a
            href="/admin/user"
            class="block text-gray-700 hover:text-blue-500 transition"
            >Users</a
          >
          <a
            href="/admin/product"
            class="block text-gray-700 hover:text-blue-500 transition font-semibold text-blue-600"
            >Products</a
          >
          <a
            href="/admin/sales-report"
            class="block text-gray-700 hover:text-blue-500 transition"
            >Sales Report</a
          >
        </nav>
      </aside>

      <!-- Main -->
      <main class="flex-1 p-8">
        <!-- Header -->
        <header class="flex justify-between items-center mb-8">
          <h1 class="text-2xl font-semibold text-gray-800">➕ Add Product</h1>
          <a
            href="/admin/product"
            class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-300 transition text-sm font-medium shadow-sm"
          >
            ← Back to Products
          </a>
        </header>

        <!-- Add Product Form -->
        <section class="bg-white shadow-md rounded-xl p-8 max-w-3xl mx-auto">
          <form
            action="/admin/product/add"
            method="POST"
            enctype="multipart/form-data"
            class="space-y-6"
          >
            <!-- Title -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Product Title</label
              >
              <input
                type="text"
                name="title"
                placeholder="Enter product title"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
              />
            </div>

            <!-- Description -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Description</label
              >
              <textarea
                name="description"
                rows="4"
                placeholder="Enter product description"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
              ></textarea>
            </div>

            <!-- Category -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Category</label
              >
              <input
                type="text"
                name="category"
                placeholder="e.g. Electronics, Clothing..."
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
              />
            </div>

            <!-- Price and Stock -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1"
                  >Price (₹)</label
                >
                <input
                  type="number"
                  name="price"
                  min="0"
                  step="0.01"
                  placeholder="0.00"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1"
                  >Stock</label
                >
                <input
                  type="number"
                  name="stock"
                  min="0"
                  placeholder="Enter stock count"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                />
              </div>
            </div>

            <!-- Image Upload -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2"
                >Product Images</label
              >
              <input
                type="file"
                id="image"
                name="images"
                multiple
                accept="image/jpeg image/png image/jpg"
                class="w-full border border-gray-300 rounded-lg px-4 py-2 bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
              />
              <div
                id="previewContainer"
                class="flex flex-wrap gap-6 mt-4"
              ></div>
              <p class="text-xs text-gray-500 mt-1">
                You can upload up to 5 images.
              </p>
            </div>

            <!-- Submit -->
            <div class="flex justify-end pt-4">
              <button
                id="saveBtn"
                type="submit"
                onclick="console.log('button clicked')"
                class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg font-medium shadow-md transition transform hover:-translate-y-0.5"
              >
                💾 Save Product
              </button>
            </div>
          </form>
        </section>
      </main>
    </div>

    <script>
      let croppers = [];

      const input = document.getElementById("image");
      const preview = document.getElementById("previewContainer");
      const form = document.querySelector("form");
      const saveButton = document.getElementById("saveBtn");

      input.addEventListener("change", function (e) {
        // destroy previous croppers
        croppers.forEach((c) => c.destroy());
        croppers = [];

        preview.innerHTML = "";

        const files = Array.from(e.target.files).slice(0, 5);
        files.forEach((file) => {
          const wrapper = document.createElement("div");
          wrapper.className =
            "w-[350px] h-[350px] relative border rounded-lg bg-gray-100";

          const img = document.createElement("img");
          const objectURL = URL.createObjectURL(file);

          img.src = objectURL;
          img.style.maxWidth = "100%";
          wrapper.appendChild(img);
          preview.appendChild(wrapper);

          img.onload = function () {
            const cropper = new Cropper(img, {
              aspectRatio: 1,
              viewMode: 1,
              autoCropArea: 0.9,

              movable: true,
              zoomable: true,

              cropBoxResizable: true,
              cropBoxMovable: true,

              dragMode: "move",
            });
            console.log("cropper:", cropper);
            console.log("cropper length:", croppers.length);

            croppers.push(cropper);
          };
        });
      });

      form.addEventListener("submit", function (e) {
        e.preventDefault();

        saveButton.disabled = true;

        const formData = new FormData();

        formData.append("title", form.title.value);
        formData.append("description", form.description.value);
        formData.append("category", form.category.value);
        formData.append("price", form.price.value);
        formData.append("stock", form.stock.value);

        if (croppers.length === 0) {
          fetch("/admin/product/add", {
            method: "POST",
            body: formData,
          })
            .then((res) => {
              if (!res.ok) throw new Error("Upload failed");
              alert("Product added successfully");
              window.location = "/admin/product";
            })
            .catch((err) => {
              console.error(err);
              alert("Upload failed");
              saveButton.disabled = false;
            });

          return;
        }

        const promises = croppers.map((cropper, index) => {
          return new Promise((resolve, reject) => {
            const canvas = cropper.getCroppedCanvas({
              width: 800,
              height: 800,
            });

            if (!canvas) {
              reject("Canvas error");
              return;
            }
            canvas.toBlob((blob) => {
              if (!blob) {
                reject("Blob conversion failed");
                return;
              }
              formData.append("images", blob, "product" + index + ".png");
              resolve();
            });
          });
        });

        Promise.all(promises)
          .then(() => {
            fetch("/admin/product/add", {
              method: "POST",
              body: formData,
            })
              .then((res) => {
                if (!res.ok) throw new Error("Upload failed");

                alert("Product added successfully");
                window.location = "/admin/product";
              })
              .catch((err) => {
                console.error(err);
                alert("Upload failed");
                saveButton.disabled = false;
              });
          })
          .catch((err) => {
            console.error(err);
            alert("Image processing failed");
            saveButton.disabled = false;
          });
      });
    </script>
  </body>
</html>
